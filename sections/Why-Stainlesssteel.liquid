{% comment %}
  Section: Why Stainless Steel
  Description: Feature section with title, description, CTA and feature cards with images/videos
  Note: Uses global fonts from base.css (supports both English and Arabic)
  Updated: Fixed 1:1 aspect ratio for all media and more compact layout
{% endcomment %}

<style>

/* Why Stainless Steel Section Styles */
.why-stainless-steel {
  width: 100%;
  isolation: isolate; /* contain all card z-indices so they never compete with the fixed header */
}

.why-stainless-steel .page-width {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Animation Keyframes — used only for the carousel dots fade-in */
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* Header Layout */
.wss-header {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin-bottom: 28px;
}

.wss-title-wrapper {
  width: 100%;
}

.wss-title {
  margin: 0;
  line-height: 1.2;
  font-family: var(--font-heading-family);
  font-size: var(--t-h1);
}

.wss-content-wrapper {
  width: 100%;
}

.wss-description {
  margin: 0;
  line-height: 1.6;
  font-family: var(--font-body-family);
  font-size: var(--t-body);
}

.wss-description p {
  margin: 0;
}

.wss-cta-wrapper {
  width: 100%;
}

.wss-cta {
  display: inline-block;
  text-decoration: underline;
  text-underline-offset: 4px;
  transition: opacity 0.2s ease;
  font-family: var(--font-body-family);
  font-size: var(--t-small);
}

.wss-cta:hover {
  opacity: 0.7;
}

/* Features Grid/Carousel Container */
.wss-features-wrapper {
  position: relative;
  overflow: hidden;
}

.wss-features {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

/* Mobile Carousel Styles */
@media screen and (max-width: 749px) {
  .wss-features {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 16px;
    padding-bottom: 16px;
  }

  .wss-features::-webkit-scrollbar {
    display: none;
  }

  .wss-feature-card {
    flex: 0 0 85%;
    scroll-snap-align: start;
    max-width: 400px;
  }

  .wss-carousel-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    margin-top: 20px;
    background-color: transparent;
  }

  .wss-carousel-dot {
    width: 20px;
    height: 2px;
    border-radius: 1px;
    background-color: rgba(200, 200, 200, 0.6);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .wss-carousel-dot:hover {
    background-color: rgba(150, 150, 150, 0.8);
  }

  .wss-carousel-dot.active {
    background-color: rgba(80, 80, 80, 0.9);
    width: 20px;
    height: 2px;
  }

  .wss-carousel-dot:focus {
    outline: 2px solid rgba(0, 0, 0, 0.3);
    outline-offset: 2px;
  }
}

/* Feature Card Styles */
.wss-feature-card {
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
  background: #ffffff;
  overflow: hidden;
}

/* Feature Image/Video Banner - FIXED 1:1 ASPECT RATIO */
.wss-feature-media {
  width: 100%;
  aspect-ratio: 1 / 1;
  position: relative;
  overflow: hidden;
}

.wss-feature-media img,
.wss-feature-media video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Video specific styles */
.wss-feature-media video {
  background-color: #000;
}

/* Icon positioned on media */
.wss-feature-icon {
  position: absolute;
  bottom: 16px;
  left: 16px;
  width: 50px;
  height: 50px;
  flex-shrink: 0;
  z-index: 2;
}

.wss-feature-icon img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* Feature Content Banner */
.wss-feature-content-banner {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  box-sizing: border-box;
  min-height: 110px;
}

.wss-feature-content {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.wss-feature-title {
  margin: 0;
  line-height: 1.2;
  font-family: var(--font-heading-family);
  font-size: var(--t-h3);
}

.wss-feature-subtitle {
  margin: 0;
  line-height: 1.3;
  font-family: var(--font-body-family);
  font-size: var(--t-subtitle);
}

.wss-feature-description {
  margin: 0;
  line-height: 1.5;
  font-family: var(--font-body-family);
  font-size: var(--t-body);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.wss-feature-description p {
  margin: 0;
}

.wss-feature-description p + p {
  margin-top: 0.4em;
}

.wss-feature-description ul,
.wss-feature-description ol {
  margin: 0.25em 0 0;
  padding-left: 1.25em;
}

.wss-feature-description li {
  margin-bottom: 0.2em;
}

/* Clickable content banner */
.wss-feature-content-banner[data-wss-expand] {
  cursor: pointer;
  transition: opacity 0.2s ease;
}

.wss-feature-content-banner[data-wss-expand]:hover {
  opacity: 0.85;
}

/* When overlay opens: stretch image to fill full card, hide banner */
.wss-feature-card.wss-overlay-open .wss-feature-media {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  aspect-ratio: unset;
  z-index: 1;
}

.wss-feature-card.wss-overlay-open .wss-feature-content-banner {
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
}

/* Full-card overlay */
.wss-feature-overlay {
  position: absolute;
  inset: 0;
  z-index: 10;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 24px;
  opacity: 0;
  transform: translateY(100%);
  pointer-events: none;
  transition: opacity 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.wss-feature-overlay.active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.wss-overlay-close {
  position: absolute;
  top: 12px;
  inset-inline-end: 12px;
  background: none;
  border: none;
  cursor: pointer;
  font-size: 22px;
  line-height: 1;
  padding: 4px 8px;
  opacity: 0.6;
  transition: opacity 0.2s ease;
}

.wss-overlay-close:hover {
  opacity: 1;
}

.wss-overlay-body {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* Smooth font rendering */
.wss-title,
.wss-description,
.wss-cta,
.wss-feature-title,
.wss-feature-subtitle,
.wss-feature-description {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Focus states for accessibility */
.wss-cta:focus-visible {
  outline: 2px solid currentColor;
  outline-offset: 4px;
  border-radius: 2px;
}

/* Tablet Styles */
@media screen and (min-width: 750px) {
  .why-stainless-steel .page-width {
    max-width: var(--page-width);
    padding: 0 40px;
  }

  .wss-header {
    grid-template-columns: 1fr 1.5fr auto;
    gap: 32px;
    align-items: flex-start;
    margin-bottom: 40px;
  }

  .wss-cta-wrapper {
    display: flex;
    align-items: flex-start;
    padding-top: 4px;
  }

  .wss-features {
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .wss-feature-icon {
    bottom: 20px;
    left: 20px;
    width: 60px;
    height: 60px;
  }

  .wss-feature-content-banner {
    padding: 20px;
  }

  .wss-carousel-dots {
    display: none;
  }
}

/* Desktop Styles */
@media screen and (min-width: 990px) {
  .why-stainless-steel .page-width {
    max-width: var(--page-width);
    padding: 0 60px;
  }

  .wss-features {
    gap: 20px;
  }

  .wss-feature-content-banner {
    padding: 20px;
  }
}

/* Large Desktop */
@media screen and (min-width: 1440px) {
  .why-stainless-steel .page-width {
    max-width: var(--page-width);
    padding: 0 80px;
  }
}

/* Reduced motion: disable overlay slide */
@media (prefers-reduced-motion: reduce) {
  .wss-feature-overlay {
    transition: opacity 0.2s ease;
    transform: none;
  }
}

/* Typography — sizes set via CSS type scale variables in class definitions above */
/* Block-specific content banner background */
{% for block in section.blocks %}
  .wss-feature-card[data-block-id="{{ block.id }}"] {
    background-color: {{ block.settings.banner_background_color }};
  }
  .wss-feature-card[data-block-id="{{ block.id }}"] .wss-feature-content-banner {
    background-color: {{ block.settings.banner_background_color }};
  }
{% endfor %}
</style>

<div class="why-stainless-steel" style="background-color: {{ section.settings.background_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="wss-header">
      <div class="wss-title-wrapper">
        {% if section.settings.title != blank %}
          <h2 class="wss-title" style="
            color: {{ section.settings.title_color }};
            font-weight: {{ section.settings.title_font_weight }};
            font-style: {{ section.settings.title_font_style }};
          ">
            {{ section.settings.title }}
          </h2>
        {% endif %}
      </div>

      <div class="wss-content-wrapper">
        {% if section.settings.description != blank %}
          <div class="wss-description" style="
            color: {{ section.settings.description_color }};
            font-weight: {{ section.settings.description_font_weight }};
            font-style: {{ section.settings.description_font_style }};
          ">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>

      <div class="wss-cta-wrapper">
        {% if section.settings.cta_text != blank %}
          <a href="{{ section.settings.cta_link }}" class="wss-cta" style="
            color: {{ section.settings.cta_color }};
            font-weight: {{ section.settings.cta_font_weight }};
            font-style: {{ section.settings.cta_font_style }};
          ">
            {{ section.settings.cta_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="wss-features-wrapper">
      <div class="wss-features" id="wss-features-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="wss-feature-card" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
            {% comment %} Check if video exists, otherwise use image {% endcomment %}
            {% if block.settings.feature_video != blank %}
              <div class="wss-feature-media">
                <video
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                >
                  {% for source in block.settings.feature_video.sources %}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {% endfor %}
                </video>
                {% if block.settings.icon != blank %}
                  <div class="wss-feature-icon">
                    <img
                      src="{{ block.settings.icon | image_url: width: 120 }}"
                      srcset="{{ block.settings.icon | image_url: width: 60 }} 60w,
                              {{ block.settings.icon | image_url: width: 120 }} 120w"
                      alt="{{ block.settings.feature_title | escape }}"
                      width="60"
                      height="60"
                      loading="lazy"
                    >
                  </div>
                {% endif %}
              </div>
            {% elsif block.settings.feature_image != blank %}
              <div class="wss-feature-media">
                <img
                  src="{{ block.settings.feature_image | image_url: width: 800 }}"
                  srcset="{{ block.settings.feature_image | image_url: width: 400 }} 400w,
                          {{ block.settings.feature_image | image_url: width: 600 }} 600w,
                          {{ block.settings.feature_image | image_url: width: 800 }} 800w,
                          {{ block.settings.feature_image | image_url: width: 1000 }} 1000w"
                  sizes="(max-width: 749px) 85vw, (max-width: 989px) 30vw, 25vw"
                  alt="{{ block.settings.feature_title | escape }}"
                  width="800"
                  height="800"
                  loading="lazy"
                >
                {% if block.settings.icon != blank %}
                  <div class="wss-feature-icon">
                    <img
                      src="{{ block.settings.icon | image_url: width: 120 }}"
                      srcset="{{ block.settings.icon | image_url: width: 60 }} 60w,
                              {{ block.settings.icon | image_url: width: 120 }} 120w"
                      alt="{{ block.settings.feature_title | escape }}"
                      width="60"
                      height="60"
                      loading="lazy"
                    >
                  </div>
                {% endif %}
              </div>
            {% endif %}

            <div class="wss-feature-content-banner" {% if block.settings.feature_description != blank and block.settings.enable_expand %}data-wss-expand aria-label="Read more about {{ block.settings.feature_title | escape }}" role="button" tabindex="0"{% endif %}>
              <div class="wss-feature-content">
                {% if block.settings.feature_title != blank %}
                  <h3 class="wss-feature-title" style="
                    color: {{ block.settings.feature_title_color }};
                    font-weight: {{ block.settings.feature_title_font_weight }};
                    font-style: {{ block.settings.feature_title_font_style }};
                  ">
                    {{ block.settings.feature_title }}
                  </h3>
                {% endif %}

                {% if block.settings.feature_subtitle != blank %}
                  <p class="wss-feature-subtitle" style="
                    color: {{ block.settings.feature_subtitle_color }};
                    font-weight: {{ block.settings.feature_subtitle_font_weight }};
                    font-style: {{ block.settings.feature_subtitle_font_style }};
                  ">
                    {{ block.settings.feature_subtitle }}
                  </p>
                {% endif %}

                {% if block.settings.feature_description != blank %}
                  <div class="wss-feature-description" style="
                    color: {{ block.settings.feature_description_color }};
                    font-weight: {{ block.settings.feature_desc_font_weight }};
                    font-style: {{ block.settings.feature_desc_font_style }};
                  ">
                    {{ block.settings.feature_description }}
                  </div>
                {% endif %}
              </div>

            </div>

            {% if block.settings.feature_description != blank and block.settings.enable_expand %}
              <div
                class="wss-feature-overlay"
                style="background-color: {{ block.settings.banner_background_color | color_modify: 'alpha', 0.93 }};"
                role="dialog"
                aria-modal="true"
                aria-hidden="true"
              >
                <button class="wss-overlay-close" aria-label="Close" style="color: {{ block.settings.feature_title_color }};">×</button>
                <div class="wss-overlay-body">
                  {% if block.settings.feature_title != blank %}
                    <h3 class="wss-feature-title" style="
                      color: {{ block.settings.feature_title_color }};
                      font-weight: {{ block.settings.feature_title_font_weight }};
                      font-style: {{ block.settings.feature_title_font_style }};
                    ">{{ block.settings.feature_title }}</h3>
                  {% endif %}
                  {% if block.settings.feature_subtitle != blank %}
                    <p class="wss-feature-subtitle" style="
                      color: {{ block.settings.feature_subtitle_color }};
                      font-weight: {{ block.settings.feature_subtitle_font_weight }};
                    ">{{ block.settings.feature_subtitle }}</p>
                  {% endif %}
                  <div class="wss-feature-description" style="
                    color: {{ block.settings.feature_description_color }};
                    font-weight: {{ block.settings.feature_desc_font_weight }};
                    font-style: {{ block.settings.feature_desc_font_style }};
                    display: block;
                    -webkit-line-clamp: unset;
                    overflow: visible;
                  ">{{ block.settings.feature_description }}</div>
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <div class="wss-carousel-dots" id="wss-dots-{{ section.id }}">
        {% for block in section.blocks %}
          <button 
            class="wss-carousel-dot {% if forloop.first %}active{% endif %}" 
            data-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const carousel  = document.getElementById('wss-features-' + sectionId);
  const dotsWrap  = document.getElementById('wss-dots-' + sectionId);

  if (!carousel) return;

  const dots  = dotsWrap ? Array.from(dotsWrap.querySelectorAll('.wss-carousel-dot')) : [];
  const cards = Array.from(carousel.querySelectorAll('.wss-feature-card'));

  /* ── overlay helpers ── */
  const expandTimers   = new Map();
  const manuallyClosed = new Set();

  function resumeVideo(card) {
    const video = card.querySelector('video');
    if (video && video.paused) video.play().catch(() => {});
  }

  function openOverlay(card) {
    const overlay = card.querySelector('.wss-feature-overlay');
    if (!overlay) return;
    card.style.minHeight = card.offsetHeight + 'px';
    card.classList.add('wss-overlay-open');
    overlay.classList.add('active');
    overlay.setAttribute('aria-hidden', 'false');
    resumeVideo(card);
  }

  function closeOverlay(card) {
    clearTimeout(expandTimers.get(card));
    card.classList.remove('wss-overlay-open');
    const overlay = card.querySelector('.wss-feature-overlay');
    if (overlay) {
      overlay.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
    }
    card.style.minHeight = '';
    resumeVideo(card);
  }

  function scheduleOpen(card, delay) {
    clearTimeout(expandTimers.get(card));
    if (manuallyClosed.has(card)) return;
    expandTimers.set(card, setTimeout(() => openOverlay(card), delay != null ? delay : 1000));
  }

  /* ── wire close buttons & manual taps on every card ── */
  cards.forEach(card => {
    const closeBtn = card.querySelector('.wss-overlay-close');
    const banner   = card.querySelector('[data-wss-expand]');

    if (closeBtn) {
      closeBtn.addEventListener('click', e => {
        e.stopPropagation();
        manuallyClosed.add(card);
        closeOverlay(card);
      });
    }
    if (banner) {
      banner.addEventListener('click', () => {
        manuallyClosed.delete(card);
        openOverlay(card);
      });
      banner.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          manuallyClosed.delete(card);
          openOverlay(card);
        }
      });
    }
  });

  /* ── mobile carousel (< 750px): expand active card on swipe ── */
  if (window.innerWidth < 750 && dots.length > 0) {
    let activeIndex = -1;

    function getMostVisible() {
      const cr = carousel.getBoundingClientRect();
      let max = -1, idx = 0;
      cards.forEach((c, i) => {
        const r = c.getBoundingClientRect();
        const w = Math.max(0, Math.min(r.right, cr.right) - Math.max(r.left, cr.left));
        if (w > max) { max = w; idx = i; }
      });
      return idx;
    }

    function updateActive() {
      const next = getMostVisible();
      if (next === activeIndex) return;

      // Close the card we're leaving and reset its state so re-entry re-triggers
      if (activeIndex >= 0 && cards[activeIndex]) {
        closeOverlay(cards[activeIndex]);
        manuallyClosed.delete(cards[activeIndex]);
      }

      activeIndex = next;
      dots.forEach((d, i) => d.classList.toggle('active', i === activeIndex));

      // 1-second delay lets the user see the image before the overlay expands
      scheduleOpen(cards[activeIndex], 1000);
    }

    carousel.addEventListener('scroll', updateActive, { passive: true });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        cards[i] && cards[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      });
    });

    // Kick off the first card when the section scrolls into view
    const sectionEl = carousel.closest('.why-stainless-steel') || carousel;
    const sectionIO = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) {
        sectionIO.disconnect();
        updateActive();
      }
    }, { threshold: 0.25 });
    sectionIO.observe(sectionEl);

  } else {
    /* ── desktop grid (≥ 750px): expand each card as it enters the viewport ── */
    const cardObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        const card  = entry.target;
        // Stagger cards that enter together: card 0 = +1 s, card 1 = +1.25 s, etc.
        const delay = 1000 + cards.indexOf(card) * 250;

        if (entry.isIntersecting && entry.intersectionRatio >= 0.45) {
          scheduleOpen(card, delay);
        } else {
          closeOverlay(card);
          manuallyClosed.delete(card); // reset so re-entry works
        }
      });
    }, { threshold: [0, 0.45] });

    cards.forEach(card => {
      if (card.querySelector('.wss-feature-overlay')) cardObserver.observe(card);
    });
  }

  /* ── close all overlays when the header menu opens ── */
  function closeAllOverlays() {
    cards.forEach(card => {
      closeOverlay(card);
      manuallyClosed.delete(card);
    });
  }

  // Mobile drawer
  const headerDrawer = document.getElementById('headerDrawer');
  if (headerDrawer) {
    new MutationObserver(function(mutations) {
      mutations.forEach(function(m) {
        if (m.attributeName === 'class' && headerDrawer.classList.contains('is-open')) {
          closeAllOverlays();
        }
      });
    }).observe(headerDrawer, { attributes: true, attributeFilter: ['class'] });
  }

  // Desktop mega menu nav items
  document.querySelectorAll('.custom-header__nav-item[data-has-mega-menu]').forEach(function(item) {
    item.addEventListener('mouseenter', closeAllOverlays);
  });
})();
</script>

{% schema %}
{
  "name": "Why Stainless Steel",
  "tag": "section",
  "class": "section-why-stainless-steel",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F5F5F5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 32
    },
    {
      "type": "header",
      "content": "Main Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Why Stainless Steel"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
